li:first-child, li + li { margin-top: 0.25rem; }

#markdown-toc li:first-child, #markdown-toc li + li { margin-top: 0px; }

li > blockquote, li > img { margin-top: 0.25rem; }

li > div.scratchblocks, li > p, li pre { margin-bottom: 0.5rem; margin-top: 0.5rem; }

mark, .mark { background-color: inherit; color: inherit; font-weight: bold; padding: 0px; }

ol > li { padding-left: 0.5rem; }

pre { padding: 0.5rem 0.75rem; }

pre code span { white-space: pre; font-style: normal !important; }

#alert, aside { box-shadow: rgba(0, 0, 0, 0.2) 0.5rem 0.5rem 1rem; }

[data-marker="+"] > span, [data-marker="-"] > span { cursor: pointer; }

[data-marker="+"] > .fa-li, [data-marker="-"] > .fa-li { user-select: none; }

[data-marker="+"] > .fa-li > .fa-plus-square, [data-marker="-"] > .fa-li > .fa-minus-square { font-size: 80%; }

[data-marker="+"] > ol, [data-marker="+"] > ul { display: none; }

[data-marker="*"] > .fa-li > .fa-square { font-size: 50%; vertical-align: 25%; }

.next { display: none; }

details > summary { font-weight: bold; }

[data-video] { background-color: rgb(0, 0, 0); margin-bottom: 1rem; }

html { font-size: 16px; }

body > div.container-fluid > div.row, body > div.container-sm > div.row, body > div.container-md > div.row, body > div.container-lg > div.row, body > div.container-xl > div.row, body > div.container-xxl > div.row { align-items: flex-start; }

aside { background-color: rgb(165, 28, 48); color: rgba(255, 255, 255, 0.5); font-size: 1.125rem; }

aside h1, aside h2, aside .h1, aside .h2 { border-bottom: 0px; }

aside li:first-child, aside li + li { margin-top: 0px; }

aside a, aside .btn-link { text-decoration: none; }

aside.col-lg { padding: 2rem; }

@media screen and (min-width: 992px) {
  aside.col-lg { flex: 0 1 20rem; overflow-y: auto; position: sticky; z-index: 1019; }
}

aside a, aside a:hover, aside .btn[data-bs-toggle="collapse"], aside .btn[data-bs-toggle="collapse"]:hover { background-color: inherit; border-color: rgb(255, 255, 255); color: rgb(255, 255, 255); }

aside .btn[data-bs-toggle="modal"], aside .btn[data-bs-toggle="modal"]:hover { color: rgb(255, 255, 255); }

aside .btn[data-bs-toggle="collapse"]:not(.collapsed) { background-color: rgb(255, 255, 255); color: rgb(165, 28, 48); }

aside hr { border-top: 1px solid rgba(255, 255, 255, 0.5); }

aside p.small { line-height: 1.25; }

aside .fa-ul { margin-left: 0px; }

aside .btn[data-bs-toggle="collapse"], aside .btn[data-bs-toggle="modal"] { margin-top: 1.25rem; }

header h1, header .h1 { font-size: 2.5rem; margin-bottom: 0.5rem; padding-bottom: 0px; }

header h2, header .h2 { font-size: 1.25rem; font-weight: normal; padding-top: 0px; }

nav > :first-child { margin-top: 1rem; }

nav ol li, nav ul li { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

nav ol { list-style-position: inside; padding-left: 0px; }

nav ol li { padding-left: 0px; }

nav ul { list-style: none; padding-left: 0px; }

nav ul ul { list-style: inside; }

footer { margin-top: 1rem; }

footer:empty { margin-top: 0px; }

main.col-lg { max-width: 80rem; overflow: auto; padding: 4rem 2rem; }

main a[data-id][id] { display: block; position: relative; visibility: hidden; }

main .alert .fa-ul { margin-left: 1.25em; }

#search ol { list-style-type: none; padding-left: 1rem; padding-right: 1rem; }

@media (max-width: 991.98px), print {
  small, h1 em, h2 em, h3 em, h4 em, h5 em, h6 em, .h1 em, .h2 em, .h3 em, .h4 em, .h5 em, .h6 em, .small { font-size: 90%; }
  aside.col-lg { padding-top: 1rem; }
  main.col-lg { padding: 2rem; }
}

@media print {
  #alert { display: none !important; }
  #search, [data-search] { display: none !important; }
  a[href^="http"]::after { content: " (" attr(href) ")"; word-break: break-word; }
  aside.col-lg { flex: unset; height: auto !important; }
  aside .btn[data-bs-toggle="collapse"] { display: none; }
  nav.collapse:not(.show), footer { display: none !important; }
}

aside { background-color: rgb(0, 0, 0); }

aside button[data-bs-toggle="collapse"]:not(.collapsed) { color: rgb(0, 0, 0); }
